{
	"Name": "Ceaika.Accuracy",
	"Description": "[[@ceaika]]\n\nExtremely amazing and superb accuracy tracker with lifetime stats",
	"Version": "3.1.0",
	"LoadPriority": 6767,
	"ConVars": [
		{ "Name": "cv_acc_simple_posX",         "DefaultValue": "0.42"  },
		{ "Name": "cv_acc_simple_posY",         "DefaultValue": "0.935" },

		{ "Name": "cv_acc_advanced_posX",         "DefaultValue": "0.42"  },
		{ "Name": "cv_acc_advanced_posY",         "DefaultValue": "0.935" },

		{ "Name": "cv_acc_font_size",     "DefaultValue": "16"    },
		{ "Name": "cv_acc_always_show",   "DefaultValue": "0"     },
		{ "Name": "cv_acc_show_shots",    "DefaultValue": "1"     },
		{ "Name": "cv_acc_show_hits",     "DefaultValue": "1"     },
		{ "Name": "cv_acc_show_lifetime", "DefaultValue": "1"     }
	],
	"Scripts": [
		{
			"Path": "Accuracy.nut",
			"RunOn": "(CLIENT || SERVER)",
			"ClientCallback": {
				"After": "Accuracy_Init"
			}
		},
		{
			"Path": "AccuracySettings.nut",
			"RunOn": "UI",
			"UICallback": {
				"Before": "AccuracySettings_Init"
			}
		}
	],
	"Localisation": []
}
